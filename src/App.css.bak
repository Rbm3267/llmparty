/* ══════════════════════════════════════════════
   App Layout Shell - Glassmorphism Edition
══════════════════════════════════════════════ */
.app-shell {
  display: flex;
  height: 100vh;
  width: 100vw;
  overflow: hidden;
  background: radial-gradient(circle at 10% 20%, rgba(34, 211, 238, 0.05) 0%, transparent 40%),
              radial-gradient(circle at 90% 80%, rgba(232, 121, 249, 0.05) 0%, transparent 40%),
              var(--bg-base);
}

/* ── Sidebar ────────────────────────────────── */
.sidebar {
  width: var(--sidebar-w);
  min-width: var(--sidebar-w);
  height: 100%;
  background: rgba(12, 8, 23, 0.4);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-right: 1px solid rgba(255, 255, 255, 0.05);
  display: flex;
  flex-direction: column;
  padding: 20px 0 20px;
  overflow: hidden;
  position: relative;
}

/* Subtle top gradient glow behind the logo */
.sidebar::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 140px;
  background: radial-gradient(ellipse at 50% -20%, rgba(168,85,247,0.15) 0%, transparent 70%);
  pointer-events: none;
}

.sidebar-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 0 18px 20px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  margin-bottom: 16px;
  position: relative;
}

.logo-mark-img {
  width: 28px;
  height: 28px;
  object-fit: contain;
  filter: drop-shadow(0 0 12px rgba(232,121,249,0.5));
}

.logo-name {
  font-size: 16px;
  font-weight: 800;
  letter-spacing: 0.5px;
  color: #fff;
  line-height: 1.1;
}

.gradient-text {
  background: linear-gradient(90deg, #22d3ee, #e879f9);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.logo-sub {
  font-size: 10px;
  color: var(--accent-cyan);
  letter-spacing: 0.5px;
  margin-top: 1px;
}

.sidebar-section-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.4);
  padding: 0 18px;
  margin-bottom: 6px;
}

.sidebar-nav {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 0 10px;
  margin-bottom: 20px;
}

.nav-item {
  position: relative;
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  padding: 10px 12px;
  border: 1px solid transparent;
  background: transparent;
  color: rgba(255, 255, 255, 0.6);
  border-radius: 10px;
  cursor: pointer;
  font-size: 13px;
  font-weight: 500;
  transition: all 0.2s ease;
}

.nav-item:hover {
  background: rgba(255, 255, 255, 0.03);
  color: #fff;
}

.nav-item.active {
  background: rgba(34, 211, 238, 0.1);
  border: 1px solid rgba(34, 211, 238, 0.3);
  color: #fff;
  box-shadow: inset 0 0 12px rgba(34, 211, 238, 0.1);
}

.nav-item.active .nav-icon {
  color: var(--accent-cyan);
}

/* ── Main View Area ─────────────────────────── */
.view-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
}

.view-header {
  padding: 24px 30px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.view-title {
  font-size: 26px;
  font-weight: 800;
  color: var(--accent-cyan);
  text-shadow: 0 0 20px rgba(34, 211, 238, 0.3);
  margin-bottom: 4px;
}

.view-subtitle {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.5);
}

.view-content {
  flex: 1;
  overflow-y: auto;
  padding: 30px;
}

/* ── Glass Cards ────────────────────────────── */
.card {
  background: rgba(255, 255, 255, 0.02);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  transition: transform 0.2s ease, border-color 0.2s ease;
}

.card:hover {
  border-color: rgba(255, 255, 255, 0.15);
}

.mcp-card {
  border: 1px solid rgba(232, 121, 249, 0.6);
  box-shadow: 0 0 20px rgba(232, 121, 249, 0.15), inset 0 0 10px rgba(232, 121, 249, 0.05);
  background: rgba(232, 121, 249, 0.02);
}

.card-title {
  font-size: 16px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}

/* Form Elements */
.field-group { display: flex; flex-direction: column; gap: 6px; }
.field-label { font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.5px; }

.field-input {
  background: rgba(0,0,0,0.2);
  border: 1px solid rgba(255,255,255,0.1);
  color: #fff;
  padding: 10px 14px;
  border-radius: 8px;
  font-size: 13px;
  transition: all 0.2s ease;
}
.field-input:focus {
  outline: none;
  border-color: var(--accent-cyan);
  box-shadow: 0 0 0 2px rgba(34, 211, 238, 0.15);
}

/* Buttons */
.btn {
  padding: 8px 16px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  transition: all 0.2s ease;
  border: none;
}
.btn-primary {
  background: linear-gradient(90deg, var(--accent-violet), var(--accent-primary));
  color: #fff;
  box-shadow: 0 4px 14px rgba(232, 121, 249, 0.4);
}
.btn-primary:hover {
  box-shadow: 0 6px 20px rgba(232, 121, 249, 0.6);
  transform: translateY(-1px);
}
.btn-ghost {
  background: rgba(255,255,255,0.05);
  color: #fff;
  border: 1px solid rgba(255,255,255,0.1);
}
.btn-ghost:hover {
  background: rgba(255,255,255,0.1);
}

/* Utility layout */
.row { display: flex; align-items: center; }
.col { display: flex; flex-direction: column; }
.sb { justify-content: space-between; }
.gap-1 { gap: 4px; }
.gap-2 { gap: 8px; }
.gap-3 { gap: 12px; }
.wrap { flex-wrap: wrap; }
.mb-2 { margin-bottom: 8px; }
.mb-3 { margin-bottom: 16px; }
.mb-4 { margin-bottom: 24px; }
.mono { font-family: 'JetBrains Mono', monospace; }

/* Integrations Grid */
.integrations-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 20px;
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  display: inline-block;
  margin-left: 6px;
}
.status-green { background: #4ade80; box-shadow: 0 0 8px #4ade80; }
.status-yellow { background: #fbbf24; box-shadow: 0 0 8px #fbbf24; }

/* Provider badges */
.provider-badge {
  padding: 4px 8px;
  border-radius: 6px;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  background: rgba(255,255,255,0.1);
}
.pb-anthropic { background: rgba(45, 212, 191, 0.15); color: #2dd4bf; }
.pb-openai    { background: rgba(147, 197, 253, 0.15); color: #93c5fd; }
.pb-local     { background: rgba(251, 191, 36, 0.15); color: #fbbf24; }

.mcp-item {
  background: rgba(0,0,0,0.2);
  border: 1px solid rgba(255,255,255,0.05);
  border-radius: 10px;
  padding: 12px;
  margin-bottom: 8px;
}
